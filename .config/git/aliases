; vim: set filetype=gitconfig:
[alias]
    adog = log --all --decorate --oneline --graph
    amend = commit --amend --no-edit
    cdf = clean -df
    last = log -1 HEAD
    st = status -s
    worktree-add = "!f() { git worktree add \"$(pwd).worktree/$1\" \"$1\"; }; f"
    worktree-remove = "!f() { git worktree remove \"$(pwd).worktree/$1\"; }; f"
